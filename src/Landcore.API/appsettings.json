{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "",
    "DatabaseName": "landcore"
  },
  "Jwt": {
    "Issuer": "Landcore",
    "Audience": "LandcoreClients",
    // SigningKey MUST be overridden via `dotnet user-secrets set "Jwt:SigningKey" "<value>"` (dev)
    // or the Jwt__SigningKey environment variable (staging/production). Left blank here on
    // purpose — Program.cs refuses to start if this resolves to an empty value outside of
    // appsettings.Development.json's local-dev-only placeholder. Never commit a real secret.
    "SigningKey": "",
    "ExpiryMinutes": 60
  },
  // Phase 13: Host/Username/Password/FromAddress MUST be overridden via
  // `dotnet user-secrets set "Smtp:Password" "<value>"` (dev) or the
  // Smtp__Host/Smtp__Username/Smtp__Password/Smtp__FromAddress environment variables (staging/
  // production). Left blank here on purpose — unlike Jwt:SigningKey, Program.cs does NOT fail to
  // start if Host is blank; EmailService.SendAsync itself throws the moment a notification is
  // actually attempted with no Host configured — see
  // Landcore.Infrastructure/Configuration/SmtpSettings.cs remarks. Never commit a real secret.
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "Landcore",
    "UseSsl": true
  },
  "Notifications": {
    // PRD Section 3.21: "installment due reminders... N days before due date" — see
    // Landcore.Application/Configuration/NotificationSettings.cs remarks.
    "InstallmentDueReminderDays": 7
  },
  "Repossession": {
    // PRD Section 3.16 resolved decision (Open Items Resolution Log): "no late fee, 1-month grace
    // period" — see Landcore.Application/Configuration/RepossessionSettings.cs remarks.
    "GraceMonths": 1
  }
}
